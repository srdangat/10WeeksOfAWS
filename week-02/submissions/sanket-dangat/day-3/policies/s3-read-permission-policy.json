{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListS3Bucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::ec2-s3-read-lab-sanket-dangat"
    },
    {
      "Sid": "AllowReadS3Objects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::ec2-s3-read-lab-sanket-dangat/*"
    }
  ]
}